# Edge Function: research — secrets/config
# Set these in Supabase: `npx supabase secrets set --env-file .env` (do NOT commit real values).
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected by Supabase at runtime;
# only set them locally when running the function with `supabase functions serve`.

# --- Required ---
OPENAI_API_KEY=sk-...                      # OpenAI key (planner + summarizer LLM)
LINKDAPI_KEYS=key1,key2                     # RapidAPI LinkdAPI key(s), comma-separated for failover
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...           # service role key (server-side only, never expose)

# --- Optional (sane defaults in code) ---
MAX_LINKDAPI_CALLS=6                        # per-job LinkdAPI call budget (default 6)
MIN_POSTS_THRESHOLD=8                       # search loop stop target (default 8)
MIN_RELEVANCE=50                            # drop posts scoring below this 0-100 (default 50)
OPENAI_PLANNER_MODEL=gpt-5                  # default gpt-5
OPENAI_SUMMARIZER_MODEL=gpt-5              # default gpt-5
